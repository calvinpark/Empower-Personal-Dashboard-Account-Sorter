{
  "manifest_version": 3,
  "name": "Empower Personal Dashboard Account Sorter",
  "version": "1.1",
  "description": "Sorts Empower Personal Dashboard (Personal Capital) accounts by balance in descending order.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "https://ira.empower-retirement.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://ira.empower-retirement.com/dashboard/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{e3903e12-da58-b0a2-d4cc-017750127e12}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
